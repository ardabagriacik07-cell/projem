<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Servis Yönetim</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="admin-body">
@{
    var admin = Context.Session.GetString("Admin");
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    var action = ViewContext.RouteData.Values["action"]?.ToString();
    var loginSayfasi = controller == "Admin" && action == "Login";
    var pageTitle = ViewData["PageTitle"]?.ToString() ?? "Servis Yönetim Paneli";
    var subtitle = ViewData["Subtitle"]?.ToString() ?? "Tüm operasyonlarını tek yerden yönet";
}

@if (loginSayfasi)
{
    <main class="admin-auth-shell container-fluid py-4 py-lg-5">
        @RenderBody()
    </main>
}
else
{
    <button class="btn admin-menu-toggle" type="button" data-bs-toggle="offcanvas" data-bs-target="#adminMenu" aria-controls="adminMenu" aria-label="Menüyü aç">
        <i class="bi bi-list"></i>
    </button>

    <div class="offcanvas offcanvas-start admin-offcanvas text-white" tabindex="-1" id="adminMenu" aria-labelledby="adminMenuLabel">
        <div class="offcanvas-header border-bottom border-light border-opacity-10">
            <div>
                <div class="brand-badge mb-2">SY</div>
                <h5 class="offcanvas-title mb-0" id="adminMenuLabel">Servis Yönetim</h5>
                <small class="admin-offcanvas-copy">Operasyon Komuta Merkezi</small>
            </div>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Kapat"></button>
        </div>
        <div class="offcanvas-body d-flex flex-column">
            <div class="admin-menu-caption">Yonetim</div>
            <a class="admin-side-link @(controller == "Home" && action == "Index" ? "active" : "")" asp-controller="Home" asp-action="Index"><i class="bi bi-speedometer2"></i><span>Dashboard</span></a>
            <a class="admin-side-link @(controller == "Home" && action == "OperasyonMerkezi" ? "active" : "")" asp-controller="Home" asp-action="OperasyonMerkezi"><i class="bi bi-diagram-3-fill"></i><span>Operasyon</span></a>
            <a class="admin-side-link @(controller == "Home" && action == "Raporlar" ? "active" : "")" asp-controller="Home" asp-action="Raporlar"><i class="bi bi-bar-chart-fill"></i><span>Raporlar</span></a>
            <a class="admin-side-link @(controller == "Home" && action == "SistemDurumu" ? "active" : "")" asp-controller="Home" asp-action="SistemDurumu"><i class="bi bi-cpu-fill"></i><span>Sistem Durumu</span></a>
            <a class="admin-side-link @(controller == "Home" && action == "Privacy" ? "active" : "")" asp-controller="Home" asp-action="Privacy"><i class="bi bi-shield-check"></i><span>Güvenlik</span></a>

            <div class="admin-menu-caption mt-4">Kayıtlar</div>
            <a class="admin-side-link @(controller == "Musteri" ? "active" : "")" asp-controller="Musteri" asp-action="Index"><i class="bi bi-people-fill"></i><span>Müşteriler</span></a>
            <a class="admin-side-link @(controller == "Cihaz" ? "active" : "")" asp-controller="Cihaz" asp-action="Index"><i class="bi bi-phone-fill"></i><span>Cihazlar</span></a>
            <a class="admin-side-link @(controller == "Servis" ? "active" : "")" asp-controller="Servis" asp-action="Index"><i class="bi bi-tools"></i><span>Servisler</span></a>
            <a class="admin-side-link @(controller == "Islem" ? "active" : "")" asp-controller="Islem" asp-action="Index"><i class="bi bi-list-check"></i><span>İşlem Kataloğu</span></a>
            <a class="admin-side-link @(controller == "Admin" && action == "SifreDegistir" ? "active" : "")" asp-controller="Admin" asp-action="SifreDegistir"><i class="bi bi-key-fill"></i><span>Admin Şifre</span></a>

            <div class="admin-side-spacer"></div>
            <div class="admin-side-panel">
                <strong>@admin</strong>
                <small>Yönetici oturumu aktif. Kritik değişiklikleri buradan yönetebilirsin.</small>
            </div>

            @if (string.IsNullOrWhiteSpace(admin) == false)
            {
                <form asp-controller="Admin" asp-action="Logout" method="post" class="mt-3">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn admin-logout-btn w-100"><i class="bi bi-box-arrow-right me-2"></i>Çıkış Yap</button>
                </form>
            }
        </div>
    </div>

    <main class="admin-shell container-fluid px-3 px-md-4 px-xl-5 py-4 py-xl-5">
        <section class="admin-topbar mb-4">
            <div>
                <div class="admin-eyebrow">Yönetim Paneli</div>
                <h1 class="admin-page-title mb-1">@pageTitle</h1>
                <p class="admin-subtitle mb-0">@subtitle</p>
            </div>
            <div class="admin-topbar-card">
                <div class="admin-topbar-icon"><i class="bi bi-stars"></i></div>
                <div>
                    <strong>Sunum Hazır Mod</strong>
                    <small>Bootstrap tabanlı premium yönetim deneyimi</small>
                </div>
            </div>
        </section>

        @if (TempData["Ok"] != null)
        {
            <div class="alert alert-success admin-alert border-0 shadow-sm"><i class="bi bi-check-circle-fill me-2"></i>@TempData["Ok"]</div>
        }
        @if (TempData["Hata"] != null)
        {
            <div class="alert alert-danger admin-alert border-0 shadow-sm"><i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Hata"]</div>
        }

        @RenderBody()
    </main>
}

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
