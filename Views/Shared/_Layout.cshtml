<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Servis Yönetim</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="admin-body">
@{
    var admin = Context.Session.GetString("Admin");
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    var action = ViewContext.RouteData.Values["action"]?.ToString();
    var loginSayfasi = controller == "Admin" && action == "Login";
}

@if (loginSayfasi)
{
    <main class="container py-5 d-flex align-items-center justify-content-center min-vh-100">
        @RenderBody()
    </main>
}
else
{
    <div class="container-fluid">
        <div class="row min-vh-100">
            <aside class="col-12 col-lg-3 col-xxl-2 p-0 border-end admin-sidebar">
                <div class="p-4 position-sticky top-0">
                    <div class="d-flex align-items-center gap-3 mb-4">
                        <div class="brand-badge">SY</div>
                        <div>
                            <h5 class="mb-0 fw-bold text-white">Servis Yönetim</h5>
                            <small class="text-white-50">Premium Yönetim Paneli</small>
                        </div>
                    </div>

                    <div class="list-group list-group-flush nav-pills-premium">
                        <a class="list-group-item list-group-item-action @(controller == "Home" ? "active" : "")" asp-controller="Home" asp-action="Index"><i class="bi bi-speedometer2 me-2"></i>Dashboard</a>
                        <a class="list-group-item list-group-item-action @(controller == "Musteri" ? "active" : "")" asp-controller="Musteri" asp-action="Index"><i class="bi bi-people me-2"></i>Müşteriler</a>
                        <a class="list-group-item list-group-item-action @(controller == "Cihaz" ? "active" : "")" asp-controller="Cihaz" asp-action="Index"><i class="bi bi-phone me-2"></i>Cihazlar</a>
                        <a class="list-group-item list-group-item-action @(controller == "Servis" ? "active" : "")" asp-controller="Servis" asp-action="Index"><i class="bi bi-wrench-adjustable-circle me-2"></i>Servis Kayıtları</a>
                        <a class="list-group-item list-group-item-action @(controller == "Islem" ? "active" : "")" asp-controller="Islem" asp-action="Index"><i class="bi bi-list-check me-2"></i>İşlem Kataloğu</a>
                        <a class="list-group-item list-group-item-action @(controller == "Admin" && action == "SifreDegistir" ? "active" : "")" asp-controller="Admin" asp-action="SifreDegistir"><i class="bi bi-shield-lock me-2"></i>Admin Şifre</a>
                    </div>

                    @if (string.IsNullOrWhiteSpace(admin) == false)
                    {
                        <form asp-controller="Admin" asp-action="Logout" method="post" class="mt-4">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-light w-100"><i class="bi bi-box-arrow-right me-2"></i>Çıkış Yap (@admin)</button>
                        </form>
                    }
                </div>
            </aside>

            <section class="col-12 col-lg-9 col-xxl-10 p-4 p-xl-5">
                <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
                    <div>
                        <h1 class="h3 fw-bold mb-1 text-dark">@(ViewData["PageTitle"] ?? "Servis Yönetim Paneli")</h1>
                        <p class="text-secondary mb-0">@(ViewData["Subtitle"] ?? "Tüm operasyonlarını tek yerden yönet")</p>
                    </div>
                    <span class="badge text-bg-light border px-3 py-2"><i class="bi bi-stars me-2"></i>Premium Mod</span>
                </div>

                @if (TempData["Ok"] != null)
                {
                    <div class="alert alert-success shadow-sm border-0"><i class="bi bi-check-circle-fill me-2"></i>@TempData["Ok"]</div>
                }
                @if (TempData["Hata"] != null)
                {
                    <div class="alert alert-danger shadow-sm border-0"><i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Hata"]</div>
                }

                @RenderBody()
            </section>
        </div>
    </div>
}

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
