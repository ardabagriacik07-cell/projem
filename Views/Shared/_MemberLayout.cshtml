<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Üye Alanı</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/member.css" asp-append-version="true" />
</head>
<body class="member-body">
@{
    var uyeAd = Context.Session.GetString("UyeAd");
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    var action = ViewContext.RouteData.Values["action"]?.ToString();
    var authSayfasi = controller == "Uye" && (action == "Giris" || action == "Kayit");
}

@if (authSayfasi)
{
    <div class="member-auth-bg">
        <main class="container min-vh-100 d-flex align-items-center justify-content-center py-5">
            @RenderBody()
        </main>
    </div>
}
else
{
    <header class="navbar navbar-expand-lg sticky-top member-navbar border-bottom">
        <div class="container-fluid px-4">
            <a class="navbar-brand fw-bold text-white" asp-controller="Uye" asp-action="Panel"><i class="bi bi-gem me-2"></i>Servis Plus</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#memberNav" aria-controls="memberNav" aria-expanded="false" aria-label="Navigasyonu aç">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="memberNav">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item"><a class="nav-link @(action == "Panel" ? "active" : "")" asp-controller="Uye" asp-action="Panel">Panel</a></li>
                    <li class="nav-item"><a class="nav-link @(action == "Taleplerim" ? "active" : "")" asp-controller="Uye" asp-action="Taleplerim">Taleplerim</a></li>
                    <li class="nav-item"><a class="nav-link @(action == "YeniTalep" ? "active" : "")" asp-controller="Uye" asp-action="YeniTalep">Yeni Talep</a></li>
                    <li class="nav-item"><a class="nav-link @(action == "Profil" ? "active" : "")" asp-controller="Uye" asp-action="Profil">Profil</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="Login">Admin</a></li>
                </ul>
                <form asp-controller="Uye" asp-action="Cikis" method="post">
                    @Html.AntiForgeryToken()
                    <button class="btn btn-outline-light"><i class="bi bi-box-arrow-right me-2"></i>Çıkış (@uyeAd)</button>
                </form>
            </div>
        </div>
    </header>

    <main class="container-fluid py-4 px-4">
        @if (TempData["UyeOk"] != null)
        {
            <div class="alert alert-success border-0 shadow-sm"><i class="bi bi-check2-circle me-2"></i>@TempData["UyeOk"]</div>
        }
        @if (TempData["UyeHata"] != null)
        {
            <div class="alert alert-danger border-0 shadow-sm"><i class="bi bi-exclamation-octagon me-2"></i>@TempData["UyeHata"]</div>
        }
        @RenderBody()
    </main>
}

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
