<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Üye Alanı</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/member.css" asp-append-version="true" />
</head>
<body class="member-body">
@{
    var uyeAd = Context.Session.GetString("UyeAd");
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    var action = ViewContext.RouteData.Values["action"]?.ToString();
    var authSayfasi = controller == "Uye" && (action == "Giris" || action == "Kayit" || action == "SifremiUnuttum" || action == "SifreSifirla");
    var pageTitle = ViewData["Title"]?.ToString() ?? "Üye Alanı";
}

@if (authSayfasi)
{
    <div class="member-auth-bg">
        <main class="container min-vh-100 d-flex align-items-center justify-content-center py-5">
            @RenderBody()
        </main>
    </div>
}
else
{
    <button class="btn member-menu-toggle" type="button" data-bs-toggle="offcanvas" data-bs-target="#memberMenu" aria-controls="memberMenu" aria-label="Menüyü aç">
        <i class="bi bi-list"></i>
    </button>

    <div class="offcanvas offcanvas-start member-offcanvas text-white" tabindex="-1" id="memberMenu" aria-labelledby="memberMenuLabel">
        <div class="offcanvas-header border-bottom border-light border-opacity-10">
            <div>
                <div class="member-brand-mark mb-2"><i class="bi bi-gem"></i></div>
                <h5 class="offcanvas-title mb-0" id="memberMenuLabel">Servis Plus</h5>
                <small class="member-offcanvas-subtitle">@uyeAd</small>
            </div>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Kapat"></button>
        </div>
        <div class="offcanvas-body d-flex flex-column">
            <a class="member-side-link @(action == "Panel" ? "active" : "")" asp-controller="Uye" asp-action="Panel">
                <i class="bi bi-grid-1x2-fill"></i>
                <span>Panel</span>
            </a>
            <a class="member-side-link @(action == "Taleplerim" ? "active" : "")" asp-controller="Uye" asp-action="Taleplerim">
                <i class="bi bi-receipt-cutoff"></i>
                <span>Taleplerim</span>
            </a>
            <a class="member-side-link @(action == "YeniTalep" ? "active" : "")" asp-controller="Uye" asp-action="YeniTalep">
                <i class="bi bi-plus-square-fill"></i>
                <span>Yeni Talep</span>
            </a>
            <a class="member-side-link @(action == "Profil" ? "active" : "")" asp-controller="Uye" asp-action="Profil">
                <i class="bi bi-person-circle"></i>
                <span>Profil</span>
            </a>
            <a class="member-side-link" asp-controller="Admin" asp-action="Login">
                <i class="bi bi-shield-lock-fill"></i>
                <span>Admin</span>
            </a>
            <div class="member-side-spacer"></div>
            <div class="member-side-note">
                Taleplerini takip et, yeni kayıt aç ve profilini tek menüden yönet.
            </div>
            <form asp-controller="Uye" asp-action="Cikis" method="post" class="mt-3">
                @Html.AntiForgeryToken()
                <button class="btn member-logout-btn w-100">
                    <i class="bi bi-box-arrow-right me-2"></i>Çıkış Yap
                </button>
            </form>
        </div>
    </div>

    <main class="member-shell container-fluid px-3 px-md-4 px-xl-5 py-4 py-md-5">
        <section class="member-topbar mb-4">
            <div>
                <div class="member-eyebrow">Üye Alanı</div>
                <h1 class="member-page-title mb-1">@pageTitle</h1>
                <p class="member-topbar-copy mb-0">Servis sürecini tek bakışta takip et ve tüm işlemlerini hızlıca yönet.</p>
            </div>
            <div class="member-profile-chip">
                <div class="member-profile-icon"><i class="bi bi-person-fill"></i></div>
                <div>
                    <strong>@uyeAd</strong>
                    <small>Hesabın aktif</small>
                </div>
            </div>
        </section>

        @if (TempData["UyeOk"] != null)
        {
            <div class="alert alert-success member-alert border-0 shadow-sm"><i class="bi bi-check2-circle me-2"></i>@TempData["UyeOk"]</div>
        }
        @if (TempData["UyeHata"] != null)
        {
            <div class="alert alert-danger member-alert border-0 shadow-sm"><i class="bi bi-exclamation-octagon me-2"></i>@TempData["UyeHata"]</div>
        }
        @RenderBody()
    </main>
}

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
