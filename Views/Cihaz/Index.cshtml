@model List<Cihaz>
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Cihazlar";
    ViewData["PageTitle"] = "Cihaz Yonetimi";
    ViewData["Subtitle"] = "Cihaz kayitlarini musteri bazli filtreleyip takip et.";

    var musteriler = ViewBag.Musteriler as List<SelectListItem> ?? new List<SelectListItem>();

    string Initials(string text)
    {
        if (string.IsNullOrWhiteSpace(text)) return "?";
        var parts = text.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(x => x[0]);
        return string.Concat(parts).ToUpperInvariant();
    }
}

<div class="card">
    <div class="card-body p-4 p-lg-5">
        <div class="entity-hero mb-4">
            <div>
                <span class="admin-chip">Cihaz Havuzu</span>
                <h3 class="mt-3 mb-2">Cihaz Yönetimi</h3>
                <p class="text-secondary mb-0">Marka, model, arıza ve müşteri bağlantılarını tek bakışta izle.</p>
            </div>
            <div class="entity-hero-stat">
                <small>Liste</small>
                <strong>@Model.Count</strong>
            </div>
        </div>

        <div class="admin-toolbar mb-4">
        <form method="get" class="admin-searchbar admin-searchbar-wide">
            <input class="input" type="text" name="q" value="@ViewBag.Q" placeholder="Marka, model veya musteri ara" />
            <select name="musteriId" class="input-like-select">
                <option value="">Tum Musteriler</option>
                @foreach (var m in musteriler)
                {
                    if (ViewBag.MusteriId?.ToString() == m.Value)
                    {
                        <option value="@m.Value" selected>@m.Text</option>
                    }
                    else
                    {
                        <option value="@m.Value">@m.Text</option>
                    }
                }
            </select>
            <button class="btn btn-outline-primary" type="submit">Filtrele</button>
        </form>
        <a asp-action="Create" class="btn btn-primary">Yeni Cihaz</a>
        </div>

    <div class="table-wrap">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Musteri</th>
                    <th>Marka / Model</th>
                    <th>Ariza</th>
                    <th>Servis</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Count == 0)
            {
                <tr><td colspan="5" class="muted">Kayit bulunamadi.</td></tr>
            }
            else
            {
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <div class="rich-cell">
                                <div class="rich-avatar">@Initials(item.Musteri?.AdSoyad ?? "?")</div>
                                <div>
                                    <strong>@item.Musteri?.AdSoyad</strong>
                                    <small>Musteri sahibi</small>
                                </div>
                            </div>
                        </td>
                        <td>
                            <div class="rich-stack">
                                <strong>@item.Marka</strong>
                                <small>@item.Model</small>
                            </div>
                        </td>
                        <td>
                            <div class="rich-stack">
                                <strong>Ariza Notu</strong>
                                <small>@item.ArizaAciklama</small>
                            </div>
                        </td>
                        <td>
                            <div class="metric-pill">
                                <strong>@item.ServisKayitlari.Count</strong>
                                <small>Servis</small>
                            </div>
                        </td>
                        <td>
                            <div class="action-cluster">
                                <a class="btn action-btn action-btn-view" asp-action="Details" asp-route-id="@item.Id"><i class="bi bi-eye"></i><span>Detay</span></a>
                                <a class="btn action-btn action-btn-edit" asp-action="Edit" asp-route-id="@item.Id"><i class="bi bi-pencil-square"></i><span>Duzenle</span></a>
                                <form asp-action="Delete" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit" class="btn action-btn action-btn-delete"><i class="bi bi-trash3"></i><span>Sil</span></button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
    </div>
</div>
