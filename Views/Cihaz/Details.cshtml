@model CihazDetailsViewModel
@{
    ViewData["Title"] = "Cihaz Detay";
    ViewData["PageTitle"] = "Cihaz Detay";
    ViewData["Subtitle"] = "Cihaza ait servis gecmisi ve durum dagilimi";

    string BadgeClass(string durum)
    {
        return durum switch
        {
            "Bekliyor" => "waiting",
            "Islemde" => "work",
            "Tamamlandi" => "done",
            "Teslim Edildi" => "delivery",
            _ => "waiting"
        };
    }
}

<div class="grid cols-2">
    <section class="card">
        <h3 style="margin-top:0">@Model.Cihaz.Marka @Model.Cihaz.Model</h3>
        <p><strong>Musteri:</strong> @Model.Cihaz.Musteri?.AdSoyad</p>
        <p><strong>Ariza Aciklamasi:</strong> @Model.Cihaz.ArizaAciklama</p>
        <div class="link-row">
            <a class="btn btn-light" asp-action="Edit" asp-route-id="@Model.Cihaz.Id">Duzenle</a>
            <a class="btn btn-primary" asp-controller="Servis" asp-action="Create">Yeni Servis</a>
        </div>
    </section>

    <section class="card">
        <h3 style="margin-top:0">Istatistik</h3>
        <p class="muted">Toplam Servis: <strong>@Model.ServisKayitlari.Count</strong></p>
        <p class="muted">Son Servis: <strong>@(Model.ServisKayitlari.FirstOrDefault()?.Tarih.ToLocalTime().ToString("dd.MM.yyyy") ?? "-")</strong></p>
    </section>
</div>

<section class="card" style="margin-top:16px">
    <h3 style="margin-top:0">Servis Gecmisi</h3>
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>Tarih</th>
                    <th>Durum</th>
                    <th>Tutar</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @if (Model.ServisKayitlari.Count == 0)
            {
                <tr><td colspan="4" class="muted">Bu cihaza ait servis kaydi yok.</td></tr>
            }
            else
            {
                @foreach (var item in Model.ServisKayitlari)
                {
                    <tr>
                        <td>@item.Tarih.ToLocalTime().ToString("dd.MM.yyyy")</td>
                        <td><span class="badge @BadgeClass(item.Durum)">@item.Durum</span></td>
                        <td>@item.ToplamFiyat.ToString("C0")</td>
                        <td><a class="btn btn-light" asp-controller="Servis" asp-action="Details" asp-route-id="@item.Id">Servis Detay</a></td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</section>
