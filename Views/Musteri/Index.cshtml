@model List<Musteri>
@{
    ViewData["Title"] = "Musteriler";
    ViewData["PageTitle"] = "Musteri Yonetimi";
    ViewData["Subtitle"] = "Arama, detay ve iletisim bilgileriyle musteri kayitlarini yonet.";

    string Initials(string text)
    {
        if (string.IsNullOrWhiteSpace(text)) return "?";
        var parts = text.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(x => x[0]);
        return string.Concat(parts).ToUpperInvariant();
    }
}

<div class="card">
    <div class="card-body p-4 p-lg-5">
        <div class="entity-hero mb-4">
            <div>
                <span class="admin-chip">Müşteri Akışı</span>
                <h3 class="mt-3 mb-2">Müşteri Yönetimi</h3>
                <p class="text-secondary mb-0">İletişim kayıtlarını, üyelik durumunu ve cihaz bağlantılarını tek ekranda düzenli biçimde takip et.</p>
            </div>
            <div class="entity-hero-stat">
                <small>Toplam Kayıt</small>
                <strong>@Model.Count</strong>
            </div>
        </div>

        <div class="admin-toolbar mb-4">
            <form method="get" class="admin-searchbar">
                <input class="input" type="text" name="q" value="@ViewBag.Q" placeholder="Ad, telefon veya email ara" />
                <button class="btn btn-outline-primary" type="submit">Ara</button>
            </form>
            <a asp-action="Create" class="btn btn-primary">Yeni Musteri</a>
        </div>

        <div class="table-wrap">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Ad Soyad</th>
                    <th>Telefon</th>
                    <th>Email</th>
                    <th>Hesap Tipi</th>
                    <th>Cihaz</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Count == 0)
            {
                <tr><td colspan="6" class="muted">Sonuc bulunamadi.</td></tr>
            }
            else
            {
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <div class="rich-cell">
                                <div class="rich-avatar">@Initials(item.AdSoyad)</div>
                                <div>
                                    <strong>@item.AdSoyad</strong>
                                    <small>#@item.Id musteri kaydi</small>
                                </div>
                            </div>
                        </td>
                        <td>
                            <div class="rich-stack">
                                <strong>@item.Telefon</strong>
                                <small>Iletisim hatti</small>
                            </div>
                        </td>
                        <td>
                            <div class="rich-stack">
                                <strong>@item.Email</strong>
                                <small>E-posta adresi</small>
                            </div>
                        </td>
                        <td>
                            @if (item.UyeHesabiVar)
                            {
                                <span class="badge-status tamamlandi">Uye Kayitli</span>
                            }
                            else
                            {
                                <span class="badge-status bekliyor">Sadece Musteri</span>
                            }
                        </td>
                        <td>
                            <div class="metric-pill">
                                <strong>@item.Cihazlar.Count</strong>
                                <small>Cihaz</small>
                            </div>
                        </td>
                        <td>
                            <div class="action-cluster">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn action-btn action-btn-view"><i class="bi bi-eye"></i><span>Detay</span></a>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn action-btn action-btn-edit"><i class="bi bi-pencil-square"></i><span>Duzenle</span></a>
                                <form asp-action="Delete" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button class="btn action-btn action-btn-delete" type="submit"><i class="bi bi-trash3"></i><span>Sil</span></button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
        </div>
    </div>
</div>
