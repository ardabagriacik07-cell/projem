@model AdminDashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    ViewData["PageTitle"] = "Komuta Dashboard";
    ViewData["Subtitle"] = "Operasyon, gelir, servis ve üye akışını aynı ekrandan yönet.";

    string BadgeClass(string durum)
    {
        return durum switch
        {
            "Bekliyor" => "bekliyor",
            "Islemde" => "islemde",
            "Tamamlandi" => "tamamlandi",
            "Teslim Edildi" => "teslim",
            _ => "bekliyor"
        };
    }
}

<section class="admin-hero mb-4">
    <div class="row g-4 align-items-center">
        <div class="col-xl-8">
            <span class="admin-chip">Executive Overview</span>
            <h2 class="admin-hero-title mt-3">Servis operasyonları tam kontrol altında.</h2>
            <p class="admin-hero-copy">Bekleyen işleri, aktif akışı, gelir performansını ve son müşteri hareketlerini tek sayfada izle. Sunum odaklı, güçlü ve okunaklı bir kontrol alanı.</p>
            <div class="d-flex flex-wrap gap-2 mt-4">
                <a asp-controller="Servis" asp-action="Create" class="btn btn-light fw-semibold"><i class="bi bi-plus-circle me-2"></i>Yeni Servis Kaydı</a>
                <a asp-action="Raporlar" class="btn btn-outline-light"><i class="bi bi-bar-chart me-2"></i>Raporları Aç</a>
            </div>
        </div>
        <div class="col-xl-4">
            <div class="admin-hero-side">
                <small>Bu Ay Gelir</small>
                <strong>@Model.BuAyCiro.ToString("C0")</strong>
                <span>@Model.YeniUyelerBuAy yeni üye, @Model.AktifServis aktif servis</span>
            </div>
        </div>
    </div>
</section>

<div class="row g-3 mb-4">
    <div class="col-12 col-sm-6 col-xxl-3"><div class="card kpi-card h-100"><div class="card-body"><small class="text-secondary">Toplam Müşteri</small><h3 class="display-6 fw-bold mb-0">@Model.ToplamMusteri</h3></div></div></div>
    <div class="col-12 col-sm-6 col-xxl-3"><div class="card kpi-card h-100"><div class="card-body"><small class="text-secondary">Toplam Cihaz</small><h3 class="display-6 fw-bold mb-0">@Model.ToplamCihaz</h3></div></div></div>
    <div class="col-12 col-sm-6 col-xxl-3"><div class="card kpi-card h-100"><div class="card-body"><small class="text-secondary">Aktif Servis</small><h3 class="display-6 fw-bold mb-0">@Model.AktifServis</h3></div></div></div>
    <div class="col-12 col-sm-6 col-xxl-3"><div class="card kpi-card h-100"><div class="card-body"><small class="text-secondary">Ortalama Tutar</small><h3 class="display-6 fw-bold mb-0">@Model.OrtalamaServisTutari.ToString("C0")</h3></div></div></div>
</div>

<div class="row g-4 mb-4">
    <div class="col-12 col-xxl-8">
        <div class="card premium-card h-100">
            <div class="card-body p-4 p-xl-5">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
                    <div>
                        <span class="admin-chip">Operasyon Haritası</span>
                        <h4 class="fw-bold mb-0 mt-2">Durum Dağılımı</h4>
                    </div>
                    <a class="btn btn-sm btn-outline-primary" asp-action="OperasyonMerkezi">Detaylı Operasyon</a>
                </div>
                <div class="row g-3 mb-4">
                    @foreach (var item in Model.DurumOzeti)
                    {
                        <div class="col-12 col-md-6">
                            <div class="status-glass @item.AccentClass">
                                <small>@item.Label</small>
                                <strong>@item.Count</strong>
                                <span>@item.Durum durumundaki servis sayısı</span>
                            </div>
                        </div>
                    }
                </div>
                <canvas id="adminOverviewChart" height="120"></canvas>
            </div>
        </div>
    </div>
    <div class="col-12 col-xxl-4">
        <div class="card premium-card h-100">
            <div class="card-body p-4">
                <span class="admin-chip">Marka Gücü</span>
                <h5 class="fw-bold mt-2">En Çok İş Alan Markalar</h5>
                <div class="stack-list mt-4">
                    @foreach (var marka in Model.MarkaOzetleri)
                    {
                        <div class="stack-row">
                            <div>
                                <strong>@marka.Marka</strong>
                                <small>@marka.CihazSayisi cihaz, @marka.ServisSayisi servis</small>
                            </div>
                            <span>@marka.ToplamCiro.ToString("C0")</span>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-12 col-xxl-8">
        <div class="card premium-card h-100">
            <div class="card-header bg-transparent border-0 p-4 pb-0 d-flex justify-content-between align-items-center">
                <div>
                    <span class="admin-chip">Canlı Liste</span>
                    <h5 class="fw-bold mb-0 mt-2">Son Servis Hareketleri</h5>
                </div>
                <a asp-controller="Servis" asp-action="Index" class="btn btn-sm btn-outline-primary">Tüm Servisler</a>
            </div>
            <div class="card-body p-4">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0 admin-table">
                        <thead>
                            <tr>
                                <th>Tarih</th>
                                <th>Müşteri</th>
                                <th>Cihaz</th>
                                <th>Durum</th>
                                <th>Tutar</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                        @if (Model.SonServisler.Count == 0)
                        {
                            <tr><td colspan="6" class="text-secondary">Henüz servis kaydı yok.</td></tr>
                        }
                        else
                        {
                            @foreach (var item in Model.SonServisler)
                            {
                                <tr>
                                    <td>@item.Tarih.ToLocalTime().ToString("dd.MM.yyyy")</td>
                                    <td>@item.Cihaz?.Musteri?.AdSoyad</td>
                                    <td>@item.Cihaz?.Marka @item.Cihaz?.Model</td>
                                    <td><span class="badge-status @BadgeClass(item.Durum)">@item.Durum</span></td>
                                    <td>@item.ToplamFiyat.ToString("C0")</td>
                                    <td><a class="btn btn-sm btn-light border" asp-controller="Servis" asp-action="Details" asp-route-id="@item.Id"><i class="bi bi-eye me-1"></i>Detay</a></td>
                                </tr>
                            }
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    <div class="col-12 col-xxl-4">
        <div class="card premium-card h-100">
            <div class="card-body p-4">
                <span class="admin-chip">Yeni Üyeler</span>
                <h5 class="fw-bold mt-2">Son Kayıt Akışı</h5>
                <div class="timeline-list mt-4">
                    @foreach (var uye in Model.SonUyeler)
                    {
                        <div class="timeline-item">
                            <div class="timeline-dot"></div>
                            <div>
                                <strong>@uye.AdSoyad</strong>
                                <small>@uye.Email</small>
                            </div>
                            <span>@uye.KayitTarihi.ToLocalTime().ToString("dd.MM")</span>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
(() => {
    const ctx = document.getElementById('adminOverviewChart');
    if (!ctx || typeof Chart === 'undefined') return;

    new Chart(ctx, {
        type: 'doughnut',
        data: {
            labels: [@Html.Raw(string.Join(", ", Model.DurumOzeti.Select(x => $"'{x.Label}'")))],
            datasets: [{
                data: [@string.Join(", ", Model.DurumOzeti.Select(x => x.Count))],
                backgroundColor: ['#f59e0b', '#38bdf8', '#10b981', '#8b5cf6'],
                borderWidth: 0
            }]
        },
        options: {
            plugins: {
                legend: {
                    position: 'bottom',
                    labels: { color: '#5b6474', usePointStyle: true, padding: 18 }
                }
            }
        }
    });
})();
</script>
}
