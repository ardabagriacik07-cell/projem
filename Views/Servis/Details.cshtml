@model ServisDetailsViewModel
@{
    ViewData["Title"] = "Servis Detay";
    ViewData["PageTitle"] = "Servis Detay";
    ViewData["Subtitle"] = "Kayit, durum ve maliyet dagilimi";

    string Initials(string text)
    {
        if (string.IsNullOrWhiteSpace(text)) return "?";
        var parts = text.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(x => x[0]);
        return string.Concat(parts).ToUpperInvariant();
    }
}

<section class="detail-hero-card mb-4">
    <div class="row g-4 align-items-center">
        <div class="col-xl-8">
            <div class="detail-hero-content">
                <div class="detail-identity">
                    <div class="detail-identity-avatar">@Initials(Model.Servis.Cihaz?.Musteri?.AdSoyad ?? $"{Model.Servis.Cihaz?.Marka}")</div>
                    <div>
                        <span class="admin-chip detail-chip-light">Servis Bilgisi</span>
                        <h2 class="detail-hero-title mt-3">@Model.Servis.Cihaz?.Marka @Model.Servis.Cihaz?.Model</h2>
                        <p class="detail-hero-copy mb-0">Servisin müşteri, cihaz, durum ve maliyet akışını güçlü bir özetle sunar.</p>
                    </div>
                </div>
                <div class="detail-quick-grid mt-4">
                    <div class="detail-quick-card">
                        <small>Musteri</small>
                        <strong>@Model.Servis.Cihaz?.Musteri?.AdSoyad</strong>
                    </div>
                    <div class="detail-quick-card">
                        <small>Tarih</small>
                        <strong>@Model.Servis.Tarih.ToLocalTime().ToString("dd.MM.yyyy")</strong>
                    </div>
                    <div class="detail-quick-card">
                        <small>Durum</small>
                        <strong>@Model.Servis.Durum</strong>
                    </div>
                    <div class="detail-quick-card">
                        <small>Cihaz</small>
                        <strong>@Model.Servis.Cihaz?.Marka @Model.Servis.Cihaz?.Model</strong>
                    </div>
                </div>
                <div class="d-flex flex-wrap gap-2 mt-4">
                    <a class="btn btn-light detail-hero-btn" asp-action="Edit" asp-route-id="@Model.Servis.Id"><i class="bi bi-pencil-square me-2"></i>Duzenle</a>
                    <a class="btn btn-outline-light detail-hero-btn" asp-action="Index"><i class="bi bi-collection me-2"></i>Tum Kayitlar</a>
                </div>
            </div>
        </div>
        <div class="col-xl-4">
            <div class="detail-side-stack">
                <div class="detail-side-stat">
                    <small>Toplam Islem</small>
                    <strong>@Model.Servis.ServisIslemler.Count</strong>
                    <span>Bağlı servis kalemi sayısı</span>
                </div>
                <div class="detail-side-stat">
                    <small>Toplam Tutar</small>
                    <strong>@Model.Servis.ToplamFiyat.ToString("C0")</strong>
                    <span>Tahmini veya kesin servis bedeli</span>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="card premium-card detail-section-card">
    <div class="card-body p-4 p-lg-5">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
        <div>
            <span class="admin-chip">Islem Dagilimi</span>
            <h3 class="mt-2 mb-0">Bagli Islem Listesi</h3>
        </div>
        <span class="section-count-pill">@Model.Servis.ServisIslemler.Count islem</span>
    </div>
    <div class="table-wrap">
        <table class="admin-table detail-table">
            <thead>
                <tr>
                    <th>Islem</th>
                    <th>Fiyat</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Servis.ServisIslemler.Count == 0)
            {
                <tr><td colspan="2" class="muted">Bu servis kaydinda secili islem yok.</td></tr>
            }
            else
            {
                @foreach (var islem in Model.Servis.ServisIslemler)
                {
                    <tr>
                        <td>
                            <div class="rich-stack">
                                <strong>@islem.Islem?.Ad</strong>
                                <small>Teknik işlem kalemi</small>
                            </div>
                        </td>
                        <td>
                            <div class="rich-stack">
                                <strong>@(islem.Islem?.Fiyat.ToString("C0") ?? "-")</strong>
                                <small>İşlem bedeli</small>
                            </div>
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
    </div>
</section>
