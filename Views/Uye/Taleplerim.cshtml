@model List<ServisKaydi>
@{
    ViewData["Title"] = "Taleplerim";

    string DurumSinif(string durum)
    {
        return durum switch
        {
            "Bekliyor" => "waiting",
            "Islemde" => "work",
            "Tamamlandi" => "done",
            "Teslim Edildi" => "delivery",
            _ => "waiting"
        };
    }
}

<section class="member-card">
    <div class="member-actions">
        <h3 style="margin:0">Servis Taleplerim</h3>
        <a class="member-btn" asp-action="YeniTalep">Yeni Talep</a>
    </div>

    <div class="member-table-wrap">
        <table class="member-table">
            <thead>
                <tr>
                    <th>Tarih</th>
                    <th>Cihaz</th>
                    <th>Ariza</th>
                    <th>Durum</th>
                    <th>Islem</th>
                    <th>Tutar</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Count == 0)
            {
                <tr><td colspan="6" class="member-muted">Henuz servis kaydin yok.</td></tr>
            }
            else
            {
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Tarih.ToLocalTime().ToString("dd.MM.yyyy")</td>
                        <td>@item.Cihaz?.Marka @item.Cihaz?.Model</td>
                        <td>@item.Cihaz?.ArizaAciklama</td>
                        <td><span class="member-pill @DurumSinif(item.Durum)">@item.Durum</span></td>
                        <td>@item.ServisIslemler.Count</td>
                        <td>@item.ToplamFiyat.ToString("C0")</td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</section>
