@model UyeSifreSifirlaViewModel
@{
    ViewData["Title"] = "Sifre Sifirla";
}

<div class="card member-auth-card shadow-lg border-0" style="max-width:560px; width:100%;">
    <div class="card-body p-4 p-md-5">
        <h1 class="h3 fw-bold mb-2">Yeni Sifre Belirle</h1>
        <p class="member-muted mb-4">Mailine gelen 6 haneli kodu gir ve yeni sifreni belirle.</p>

        <form asp-action="SifreSifirla" method="post" class="row g-3">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="member-validation"></div>

            <div class="col-12">
                <label asp-for="Email" class="form-label">E-posta</label>
                <input asp-for="Email" class="form-control member-input" />
                <span asp-validation-for="Email" class="member-validation"></span>
            </div>

            <div class="col-12">
                <label asp-for="Kod" class="form-label">6 Haneli Kod</label>
                <input asp-for="Kod" class="form-control member-input" maxlength="6" inputmode="numeric" />
                <span asp-validation-for="Kod" class="member-validation"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="YeniSifre" class="form-label">Yeni Sifre</label>
                <input asp-for="YeniSifre" type="password" class="form-control member-input" />
                <span asp-validation-for="YeniSifre" class="member-validation"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="YeniSifreTekrar" class="form-label">Yeni Sifre Tekrar</label>
                <input asp-for="YeniSifreTekrar" type="password" class="form-control member-input" />
                <span asp-validation-for="YeniSifreTekrar" class="member-validation"></span>
            </div>

            <div class="col-12 d-grid gap-2">
                <button type="submit" class="btn btn-success fw-semibold">Sifreyi Guncelle</button>
                <a class="btn btn-outline-light" asp-action="Giris">Giris Ekranina Don</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
