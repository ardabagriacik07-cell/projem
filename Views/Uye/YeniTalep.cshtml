@model UyeTalepCreateViewModel
@{
    ViewData["Title"] = "Yeni Talep";
}

<section class="member-card member-form-card" style="max-width:980px">
    <div class="p-4 p-lg-5">
    <span class="member-section-badge">Yeni Kayıt</span>
    <h3 class="mt-3">Yeni Servis Talebi Ac</h3>
    <p class="member-muted">Olusturdugun talep sadece sana ozel gorunur. Admin panelde tum talepleri gorebilir.</p>

    <form asp-action="YeniTalep" method="post" class="row g-4 mt-1">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="member-validation col-12"></div>

        <div class="col-md-6">
            <label asp-for="Marka" class="form-label">Marka</label>
            <input asp-for="Marka" class="form-control member-input" />
            <span asp-validation-for="Marka" class="member-validation"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="Model" class="form-label">Model</label>
            <input asp-for="Model" class="form-control member-input" />
            <span asp-validation-for="Model" class="member-validation"></span>
        </div>

        <div class="col-12">
            <label asp-for="ArizaAciklama" class="form-label">Ariza Aciklamasi</label>
            <textarea asp-for="ArizaAciklama" rows="6" class="form-control member-textarea"></textarea>
            <span asp-validation-for="ArizaAciklama" class="member-validation"></span>
        </div>

        <div class="col-12 d-flex flex-wrap gap-2">
            <button type="submit" class="btn btn-info fw-semibold px-4">Talebi Gonder</button>
            <a class="btn btn-outline-light px-4" asp-action="Taleplerim">Vazgec</a>
        </div>
    </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
