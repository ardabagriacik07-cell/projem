@model AdminSifreDegistirViewModel
@{
    ViewData["Title"] = "Admin Sifre";
    ViewData["PageTitle"] = "Admin Sifre Degistir";
    ViewData["Subtitle"] = "Yonetim paneli sifreni guvenli sekilde guncelle.";
}

<div class="card" style="max-width:700px">
    <div class="card-body p-4 p-lg-5">
        <span class="admin-chip">Kimlik Güvenliği</span>
        <h3 class="mt-3">Admin Şifre Güncelle</h3>
        <p class="text-secondary mb-4">Yönetici hesabının erişim güvenliğini korumak için güçlü ve güncel bir şifre kullan.</p>

        <form asp-action="SifreDegistir" method="post" class="row g-4">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="validation col-12"></div>

            <div class="col-12">
                <label asp-for="MevcutSifre" class="form-label">Mevcut Sifre</label>
                <input asp-for="MevcutSifre" class="input" type="password" />
                <span asp-validation-for="MevcutSifre" class="validation"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="YeniSifre" class="form-label">Yeni Sifre</label>
                <input asp-for="YeniSifre" class="input" type="password" />
                <span asp-validation-for="YeniSifre" class="validation"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="YeniSifreTekrar" class="form-label">Yeni Sifre Tekrar</label>
                <input asp-for="YeniSifreTekrar" class="input" type="password" />
                <span asp-validation-for="YeniSifreTekrar" class="validation"></span>
            </div>

            <div class="col-12 d-flex flex-wrap gap-2">
                <button type="submit" class="btn btn-primary">Sifreyi Guncelle</button>
                <a class="btn btn-outline-secondary" asp-controller="Home" asp-action="SistemDurumu">Sistem Durumuna Don</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
