@model List<Islem>
@{
    ViewData["Title"] = "İşlem Kataloğu";
    ViewData["PageTitle"] = "Servis İşlem Kataloğu";
    ViewData["Subtitle"] = "Fiyatlandırma kalemlerini modern ve hızlı bir şekilde yönet.";
}

<div class="card premium-card">
    <div class="card-body">
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
            <form method="get" class="row g-2 align-items-center flex-grow-1" style="max-width: 520px;">
                <div class="col">
                    <input class="form-control" type="text" name="q" value="@ViewBag.Q" placeholder="İşlem adı ara..." />
                </div>
                <div class="col-auto">
                    <button class="btn btn-primary"><i class="bi bi-search me-1"></i>Ara</button>
                </div>
            </form>
            <a asp-action="Create" class="btn btn-success"><i class="bi bi-plus-circle me-1"></i>Yeni İşlem</a>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>İşlem Adı</th>
                        <th>Fiyat</th>
                        <th class="text-end">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Count == 0)
                {
                    <tr><td colspan="3" class="text-secondary">İşlem bulunamadı.</td></tr>
                }
                else
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@item.Ad</td>
                            <td>@item.Fiyat.ToString("C0")</td>
                            <td class="text-end">
                                <a class="btn btn-sm btn-outline-primary me-1" asp-action="Edit" asp-route-id="@item.Id"><i class="bi bi-pencil-square me-1"></i>Düzenle</a>
                                <form asp-action="Delete" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button class="btn btn-sm btn-outline-danger" type="submit"><i class="bi bi-trash me-1"></i>Sil</button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
